# Copy to .env.local for local dev and fill in real values.
# In production set these in the Vercel dashboard
# (Project → Settings → Environment Variables). Never commit real secrets.

# BetBolt referral API — https://openapi.betbolt.com/docs/
BETBOLT_API_KEY=bb_secret_key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CaseBattle deal leaderboard (id + password from your CaseBattle deal URL)
CASEBATTLE_DEAL_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
CASEBATTLE_PASSWORD=xxxxxxxx

# --- Discord login / admin panel ---
# Create an app at https://discord.com/developers/applications and add
# OAuth2 redirect URIs: http://localhost:5173/api/auth/callback (dev)
# and https://<your-domain>/api/auth/callback (prod).
DISCORD_CLIENT_ID=xxxxxxxxxxxxxxxxxx
DISCORD_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Comma-separated Discord user IDs and/or usernames allowed into /admin
# (numeric IDs are safer — usernames stop working if the user renames)
ADMIN_DISCORD_IDS=111111111111111111,someusername
# Random string used to sign session cookies (e.g. `openssl rand -base64 32`)
SESSION_SECRET=change-me
# Optional: canonical site origin for OAuth redirects (else derived from request)
# SITE_URL=https://nsbrooklyn.com

# --- Settings persistence in production (admin panel saves) ---
# Provision Vercel KV / Upstash Redis and set (auto-set by Vercel KV):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
